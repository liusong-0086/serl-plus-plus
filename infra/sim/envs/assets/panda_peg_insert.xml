<mujoco model="panda_peg_insert">
  <include file="panda_hand.xml"/>
  <include file="peg_hole.xml"/>

  <option timestep=".002"/>

  <statistic center="0.3 0 0.4" extent=".8"/>

  <visual>
    <headlight diffuse=".4 .4 .4" ambient=".5 .5 .5"/>
    <global azimuth="160" elevation="-20" offheight="128" offwidth="128"/>
    <quality offsamples="8"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1=".3 .5 .7" rgb2="0 0 0" width="32" height="512"/>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="2 2" texuniform="true" reflectance="0"/>
  </asset>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1" diffuse="1 1 1" specular=".3 .3 .3"/>
    <light pos="0 -.5 .4" mode="targetbodycom" target="hole" diffuse=".8 .8 .8" specular=".3 .3 .3"/>
    <geom name="floor" size="3 3 0.01" type="plane" material="grid"/>
    <body name="end_effector" pos=".15 0 .5" quat="1 0 0 0" mocap="true">
      <geom name="end_effector" type="box" size=".03 .03 .03" contype="0" conaffinity="0" rgba=".6 .3 .3 0"/>
    </body>
  </worldbody>

  <equality>
    <weld name="grasp_weld" body1="left_finger" body2="peg" relpose="0 -0.012 0.05 1 0 0 0" solref="0.001 1" solimp="0.99 0.99 0.0001"/>
  </equality>
</mujoco>
